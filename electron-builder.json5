{
  productName: "BloomPUB Viewer",
  appId: "org.sil.bloompub-viewer",
  directories: {
    output: "output",
  },
  files: ["dist/electron/**/*"],
  fileAssociations: [
    {
      ext: "bloomd",
      name: "BloomPUB File",
      role: "Viewer",
    },
    {
      ext: "bloompub",
      name: "BloomPUB File",
      role: "Viewer",
    },
    {
      ext: "BloomPUB",
      name: "BloomPUB File",
      role: "Viewer",
    },
    {
      ext: "bloomPUB",
      name: "BloomPUB File",
      role: "Viewer",
    },
    {
      ext: "bloom",
      name: "Bloom Source Book File",
      role: "Viewer",
    },
    {
      ext: "bloomSource",
      name: "Bloom Source Book File",
      role: "Viewer",
    },
  ],
  win: {
    target: "nsis",
    icon: "assets/windows.ico",
    publish: ["github"],
  },
  dmg: {
    contents: [
      {
        x: 410,
        y: 150,
        type: "link",
        path: "/Applications",
      },
      {
        x: 130,
        y: 150,
        type: "file",
      },
    ],
  },
  mac: {
    icon: "assets/icon.icns",
  },
  linux: {
    target: "deb",
    maintainer: "stephen_mcconnel@sil.org",
    icon: "assets/linux",
  },
  deb: {
    // This file provides the information needed by AppArmor to allow bloompub-viewer to run.
    appArmorProfile: "assets/deb/bloompub-viewer",
    // These files fix a bug in detecting user namespaces, and also a bug in allowing spaces
    // in the destination directory name.  Spaces are technically legal, but a lot of Linux
    // software (like AppArmor) doesn't allow for them.
    afterInstall: "assets/deb/postinst.sh",
    afterRemove: "assets/deb/postrm.sh",
  },
}
